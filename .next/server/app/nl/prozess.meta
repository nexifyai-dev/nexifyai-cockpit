{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/prozess/layout,_N_T_/[locale]/prozess/page,_N_T_/nl/prozess"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/prozess/__PAGE__",
    "/$d$locale/prozess",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}