{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/ki-hinweise/layout,_N_T_/[locale]/ki-hinweise/page,_N_T_/nl/ki-hinweise"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/ki-hinweise/__PAGE__",
    "/$d$locale/ki-hinweise",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}