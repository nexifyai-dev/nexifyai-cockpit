{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/cookie-richtlinie/layout,_N_T_/[locale]/cookie-richtlinie/page,_N_T_/nl/cookie-richtlinie"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/cookie-richtlinie/__PAGE__",
    "/$d$locale/cookie-richtlinie",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}