0:{"rsc":["$","$1","c",{"children":[["$","main",null,{"children":[["$","section",null,{"className":"subpage-hero","children":["$","div",null,{"className":"site-container","children":[["$","$L2",null,{"children":["$","span",null,{"className":"inline-flex w-fit items-center rounded-full border border-[var(--border)] bg-[var(--bg-surface)] px-3 py-1.5 font-mono text-[10px] font-normal uppercase tracking-[.16em] text-[var(--text-3)]","children":"Veelgestelde vragen"}]}],["$","$L2",null,{"delay":100,"children":["$","h1",null,{"children":"Duidelijke antwoorden vóór de projectstart."}]}],["$","$L2",null,{"delay":200,"children":["$","p",null,{"children":"De belangrijkste punten over prijs, omvang en samenwerking."}]}]]}]}],["$","section",null,{"className":"site-container max-w-4xl pb-8","children":[["$","$L3",null,{"stagger":60,"className":"faq-list","children":[["$","details","Wie kann eine vollständige Website in zwei bis drei Tagen entstehen?",{"open":true,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",1]}],"Wie kann eine vollständige Website in zwei bis drei Tagen entstehen?"]}],["$","p",null,{"children":"Nicht durch Weglassen von Qualität, sondern durch einen standardisierten Ablauf, wiederverwendbare technische Grundlagen, ein konsistentes Designsystem und AI-gestützte Analyse-, Entwicklungs- und Prüfprozesse. Pascal Courbois führt Konzeption, Architektur, Umsetzung und Qualitätskontrolle persönlich zusammen."}]]}],["$","details","Welche Rolle spielt AI in der Entwicklung?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",2]}],"Welche Rolle spielt AI in der Entwicklung?"]}],["$","p",null,{"children":"NeXify arbeitet AI-gestützt. Moderne Werkzeuge unterstützen Recherche, Strukturierung, Codeerstellung, Tests und Dokumentation. Fachliche Entscheidungen, Verantwortung, Prüfung und Freigabe bleiben beim erfahrenen Entwickler."}]]}],["$","details","Sind 999 Euro pro Arbeitstag ein Festpreis?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",3]}],"Sind 999 Euro pro Arbeitstag ein Festpreis?"]}],["$","p",null,{"children":"Der Tagessatz ist fest. Vor Beginn erhalten Sie eine belastbare Aufwandsspanne. Ein verbindlicher Gesamtfestpreis ist möglich, sobald Umfang, Inhalte, Integrationen und Abnahmekriterien eindeutig feststehen."}]]}],["$","details","Was ist in einem Arbeitstag enthalten?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",4]}],"Was ist in einem Arbeitstag enthalten?"]}],["$","p",null,{"children":"Bis zu acht planbare Fachstunden für Konzeption, Designsystem, Entwicklung, Integration, Tests und Dokumentation. Fremdkosten wie Hosting, Domains, Zahlungsanbieter, Lizenzen, Inhalte oder Stockmaterial sind nicht enthalten, sofern nicht ausdrücklich vereinbart."}]]}],["$","details","Warum ist der Gesamtpreis trotz Fachmann-Niveau so niedrig?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",5]}],"Warum ist der Gesamtpreis trotz Fachmann-Niveau so niedrig?"]}],["$","p",null,{"children":"Weil nicht mehrere Abteilungen, Übergaben und lange Agenturketten bezahlt werden. Ein erfahrener Ansprechpartner steuert den gesamten Prozess und nutzt hochmoderne AI-gestützte Werkzeuge, Automatisierung und geprüfte Open-Source-Bausteine, um die Durchlaufzeit stark zu verkürzen."}]]}],["$","details","Gilt immer 21 Prozent BTW?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",6]}],"Gilt immer 21 Prozent BTW?"]}],["$","p",null,{"children":"Die Website zeigt den niederländischen Standardsatz von 21 Prozent als transparente Vergleichsrechnung. Bei grenzüberschreitenden B2B-Leistungen innerhalb der EU kann bei gültiger Umsatzsteuer-ID das Reverse-Charge-Verfahren gelten. Maßgeblich sind Rechnungsempfänger, Leistungsort und steuerliche Voraussetzungen."}]]}],"$L4","$L5","$L6","$L7"]}],"$L8"]}]]}],["$L9"],"$La"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"vKk2H0KdAJlYczwobdWh3"}
4:["$","details","Arbeitet NeXify ausschließlich für Unternehmen?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",7]}],"Arbeitet NeXify ausschließlich für Unternehmen?"]}],["$","p",null,{"children":"Ja. Angebote und Verträge richten sich ausschließlich an Unternehmer, juristische Personen und vergleichbare beruflich handelnde Organisationen."}]]}]
5:["$","details","Welche Technologien werden eingesetzt?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",8]}],"Welche Technologien werden eingesetzt?"]}],["$","p",null,{"children":"Je nach Ziel unter anderem Next.js, React, TypeScript, Shadcn-basierte Designsysteme, moderne Datenbanken und APIs, Vercel oder geeignete Self-Hosting-Infrastruktur. Technologie folgt dem Betrieb – nicht umgekehrt."}]]}]
6:["$","details","Was passiert nach der Übergabe?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",9]}],"Was passiert nach der Übergabe?"]}],["$","p",null,{"children":"Sie erhalten den vollständigen Quellcode, Dokumentation, Betriebsinformationen und eine priorisierte Liste sinnvoller nächster Schritte. Es gibt keinen Lock-in. Sie können den Code weiterentwickeln lassen, wo Sie wollen."}]]}]
7:["$","details","Kann ich ein konkretes Beispiel sehen?",{"open":false,"children":[["$","summary",null,{"children":[["$","span",null,{"children":["0",10]}],"Kann ich ein konkretes Beispiel sehen?"]}],["$","p",null,{"children":"Vertrauliche Kundenprojekte werden nicht ungefragt veröffentlicht. In einem kostenlosen Erstgespräch können wir aber über vergleichbare Projekte sprechen und Ihnen eine Referenz-URL zeigen, die für Ihre Branche relevant ist."}]]}]
