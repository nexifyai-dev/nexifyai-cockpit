{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/leistungen/layout,_N_T_/[locale]/leistungen/page,_N_T_/en/leistungen"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/leistungen/__PAGE__",
    "/$d$locale/leistungen",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}