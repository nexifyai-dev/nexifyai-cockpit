{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/plattform/layout,_N_T_/[locale]/plattform/page,_N_T_/en/plattform"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/plattform/__PAGE__",
    "/$d$locale/plattform",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}