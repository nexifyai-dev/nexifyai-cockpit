{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/avv/layout,_N_T_/[locale]/avv/page,_N_T_/de/avv"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/avv/__PAGE__",
    "/$d$locale/avv",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}