{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/datenschutz/layout,_N_T_/[locale]/datenschutz/page,_N_T_/de/datenschutz"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/datenschutz/__PAGE__",
    "/$d$locale/datenschutz",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}