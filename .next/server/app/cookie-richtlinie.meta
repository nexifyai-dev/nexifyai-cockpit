{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/cookie-richtlinie/layout,_N_T_/cookie-richtlinie/page,_N_T_/cookie-richtlinie"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/cookie-richtlinie/__PAGE__",
    "/cookie-richtlinie",
    "/_index",
    "/_head"
  ]
}