{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/referenzen/layout,_N_T_/[locale]/referenzen/page,_N_T_/en/referenzen"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/referenzen/__PAGE__",
    "/$d$locale/referenzen",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}