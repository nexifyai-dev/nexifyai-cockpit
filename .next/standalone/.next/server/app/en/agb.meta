{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/agb/layout,_N_T_/[locale]/agb/page,_N_T_/en/agb"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/agb/__PAGE__",
    "/$d$locale/agb",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}