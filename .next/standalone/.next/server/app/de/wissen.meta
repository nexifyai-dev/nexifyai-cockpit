{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/wissen/layout,_N_T_/[locale]/wissen/page,_N_T_/de/wissen"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/wissen/__PAGE__",
    "/$d$locale/wissen",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}