{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/ueber-mich/layout,_N_T_/[locale]/ueber-mich/page,_N_T_/nl/ueber-mich"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/ueber-mich/__PAGE__",
    "/$d$locale/ueber-mich",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}