{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/preise/layout,_N_T_/[locale]/preise/page,_N_T_/nl/preise"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/preise/__PAGE__",
    "/$d$locale/preise",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}