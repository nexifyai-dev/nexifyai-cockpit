{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/[locale]/layout,_N_T_/[locale]/impressum/layout,_N_T_/[locale]/impressum/page,_N_T_/nl/impressum"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/$d$locale/impressum/__PAGE__",
    "/$d$locale/impressum",
    "/$d$locale",
    "/_index",
    "/_head"
  ]
}